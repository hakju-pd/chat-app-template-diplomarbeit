# ============================================================
#  Vorlage für die .env Datei
# ============================================================
#  SO GEHT'S:
#    1. Kopiere diese Datei und nenne die Kopie  ".env"
#    2. Trage deine beiden Werte aus Supabase ein
#       (Supabase -> Project Settings -> API)
#
#  ACHTUNG: Die .env Datei mit den echten Werten NICHT teilen
#  und NICHT auf GitHub hochladen!
# ============================================================

# Deine Projekt-URL, z.B. https://abcdefgh.supabase.co
SUPABASE_URL=

# Der "service_role" Schlüssel (NICHT der "anon" Schlüssel!)
# Das ist ein Admin-Schlüssel -> geheim halten!
SUPABASE_SERVICE_KEY=
